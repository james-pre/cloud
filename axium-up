#!/bin/bash

set -euo pipefail

root="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

cd "$root"

sudo -u axium git pull
sudo -u axium npm clean-install
sudo -u axium npx axium database upgrade
sudo -u axium npx axium link
sudo -u axium npm run build
sudo systemctl daemon-reload
sudo systemctl restart axium