#!/bin/bash

set -euo pipefail

root="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

commit=false
remote=""

while [[ $# -gt 0 ]]; do
	case "$1" in
		-c | --commit)
			commit=true
			shift
			;;
		-R | --remote)
			remote="$2"
			shift 2
			;;
		-h | --help)
			cat <<- EOF
				Usage: $0 [options]

				Update Axium packages, verify the build, and optionally commit and deploy.

				Options:
				    -c, --commit        Commit and push the update
				    -R, --remote <id>   Deploy on a remote host via ssh <id> ./axium-up
				    -h, --help          Show this help message
			EOF
			exit 0
			;;
		*)
			echo "Unknown option: $1" >&2
			exit 1
			;;
	esac
done

cd "$root"

get_versions() {
	local -n _versions=$1
	for pkg in $(jq -r '.dependencies | to_entries[] | select(.key | startswith("@axium/")) | "\(.key)=\(.value)"' package.json); do
		local name="${pkg%%=*}"
		local version="${pkg#*=}"
		_versions["$name"]="${version#^}"
	done
}

if [[ -n "$(git status --porcelain)" ]]; then
	echo "Error: Working directory is not clean. Commit or stash changes first." >&2
	exit 1
fi

declare -A old_versions
get_versions old_versions

"$root/use" latest

declare -A new_versions
get_versions new_versions

updates=()
for name in "${!new_versions[@]}"; do
	old="${old_versions[$name]:-}"
	new="${new_versions[$name]}"
	if [[ "$old" != "$new" ]]; then
		updates+=("$name $old->$new")
	fi
done

if [[ ${#updates[@]} -eq 0 ]]; then
	echo "No packages were updated."
	exit 0
fi

npx tsc --noEmit -p "$root/src/tsconfig.json"
npx vite build 2>&1 >/dev/null | grep -v 'The `config.kit'; npx axium serve

IFS=$'\n' sorted=($(sort <<< "${updates[*]}")); unset IFS
printf "Updated:\n"
printf "%s\n" "${sorted[@]}"

if [[ "$commit" == true ]]; then
	description=$(printf "%s\n" "${sorted[@]}")
	git commit -am "Updated axium" -m "$description"
	git push
fi

if [[ -n "$remote" ]]; then
	ssh "$remote" ./axium-up
fi
