{
	"name": "localcloud",
	"version": "0.0.1",
	"description": "",
	"private": true,
	"license": "GPL-3.0-or-later",
	"author": "James Prevett",
	"type": "module",
	"main": "index.js",
	"scripts": {
		"serve": "axium serve",
		"clean": "rm -rf build",
		"build": "npx vite build 2>.vite_err >/dev/null; s=$?; grep -v -e 'The `config.kit' -e 'Circular dependency:' -e 'is imported from external module \".*\" but never used in' .vite_err; rm -f .vite_err; exit $s",
		"dev": "npm run build; npx axium serve"
	},
	"dependencies": {
		"@axium/calendar": "^0.4.2",
		"@axium/client": "^0.20.1",
		"@axium/core": "^0.24.0",
		"@axium/notes": "^0.3.13",
		"@axium/server": "^0.40.1",
		"@axium/storage": "^0.21.0",
		"@axium/tasks": "^0.4.12",
		"semver": "^7.7.3",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.4.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"typescript": "^5.9.3",
		"vite-plugin-mkcert": "^1.17.9"
	},
	"prettier": {
		"plugins": [
			"prettier-plugin-svelte"
		],
		"singleQuote": true,
		"useTabs": true,
		"trailingComma": "es5",
		"tabWidth": 4,
		"printWidth": 140,
		"arrowParens": "avoid"
	},
	"axium": {
		"server": {
			"hooks": "./src/common.ts"
		}
	}
}
