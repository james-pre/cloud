{
	"name": "localcloud",
	"version": "0.0.1",
	"description": "",
	"private": true,
	"license": "GPL-3.0-or-later",
	"author": "James Prevett",
	"type": "module",
	"main": "index.js",
	"scripts": {
		"serve": "axium serve",
		"clean": "rm -rf build",
		"build": "axium build",
		"dev": "axium dev"
	},
	"dependencies": {
		"@axium/calendar": "^0.5.1",
		"@axium/client": "^0.33.1",
		"@axium/contacts": "^0.3.2",
		"@axium/core": "^0.35.0",
		"@axium/notes": "^0.4.3",
		"@axium/server": "^0.50.0",
		"@axium/storage": "^0.30.1",
		"@axium/sysadmin": "^0.2.4",
		"@axium/tasks": "^0.5.3",
		"semver": "^7.7.3",
		"svelte": "^5.55.1",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.4.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^4.1.0",
		"typescript": "^6.0.2"
	},
	"overrides": {
		"@sveltejs/kit": "2.56.1",
		"vite": "^8.0.5"
	},
	"prettier": {
		"plugins": [
			"prettier-plugin-svelte"
		],
		"singleQuote": true,
		"useTabs": true,
		"trailingComma": "es5",
		"tabWidth": 4,
		"printWidth": 140,
		"arrowParens": "avoid"
	},
	"axium": {
		"server": {
			"hooks": "./src/common.ts",
			"web_client_hooks": "./src/client.ts"
		}
	},
	"allowScripts": {
		"file:../axium/packages/server": true,
		"@axium/server": true,
		"sharp": true,
		"esbuild": true
	}
}
